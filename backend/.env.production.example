# =============================================================================
# GengoWatcher SaaS - Production Environment Configuration
# =============================================================================
# IMPORTANT: Copy this file to .env.production and fill in ALL values
# Never commit .env.production to version control!
# =============================================================================

# -----------------------------------------------------------------------------
# Server Configuration
# -----------------------------------------------------------------------------
PORT=8000
ENV=production

# -----------------------------------------------------------------------------
# Database (PostgreSQL)
# -----------------------------------------------------------------------------
# Use a managed PostgreSQL service (AWS RDS, GCP Cloud SQL, etc.)
DB_HOST=your-db-host.amazonaws.com
DB_PORT=5432
DB_USER=gengowatcher_prod
DB_PASSWORD=<STRONG_PASSWORD_HERE>
DB_NAME=gengowatcher_production
DB_SSLMODE=require

# Alternative: Connection string format
# DATABASE_URL=postgres://user:password@host:5432/dbname?sslmode=require

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
# Use a managed Redis service (AWS ElastiCache, Redis Cloud, etc.)
REDIS_URL=redis://:password@your-redis-host:6379/0

# -----------------------------------------------------------------------------
# Watcher Browser Worker
# -----------------------------------------------------------------------------
# Use a Chromium-family browser installed on the server.
WATCHER_BROWSER_BINARY=/usr/bin/chromium
WATCHER_BROWSER_PROFILE_ROOT=/var/lib/gengowatcher/browser-profiles
WATCHER_BROWSER_ARTIFACT_ROOT=/var/lib/gengowatcher/browser-artifacts
WATCHER_BROWSER_HEADLESS=true
WATCHER_BROWSER_DISABLED=false
WATCHER_BROWSER_START_TIMEOUT=15s
WATCHER_BROWSER_ACTION_TIMEOUT=12s
WATCHER_BROWSER_HEARTBEAT_INTERVAL=30s
WATCHER_BROWSER_ACCEPT_SELECTOR=text=Accept

# -----------------------------------------------------------------------------
# Security - JWT
# -----------------------------------------------------------------------------
# CRITICAL: Generate a strong random secret (minimum 32 characters)
# Generate with: openssl rand -base64 32
JWT_SECRET=<GENERATE_STRONG_SECRET_HERE>

# -----------------------------------------------------------------------------
# CORS & Cookies
# -----------------------------------------------------------------------------
# Your production frontend URL(s), comma-separated
ALLOWED_ORIGINS=https://app.gengowatcher.com,https://www.gengowatcher.com

# OAuth callback base URL (your backend URL)
OAUTH_REDIRECT_URL=https://api.gengowatcher.com

# -----------------------------------------------------------------------------
# Email (Resend)
# -----------------------------------------------------------------------------
# Get your API key from https://resend.com
RESEND_API_KEY=re_xxxxxxxxxxxx
FROM_EMAIL=noreply@gengowatcher.com
FROM_NAME=GengoWatcher

# -----------------------------------------------------------------------------
# OAuth Providers
# -----------------------------------------------------------------------------
# Google OAuth - https://console.cloud.google.com/apis/credentials
GOOGLE_OAUTH_CLIENT_ID=xxxxx.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=GOCSPX-xxxxxxxxxxxx

# GitHub OAuth - https://github.com/settings/developers
GITHUB_OAUTH_CLIENT_ID=Iv1.xxxxxxxxxxxx
GITHUB_OAUTH_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxx

# -----------------------------------------------------------------------------
# Payments (LemonSqueezy)
# -----------------------------------------------------------------------------
# Get from https://app.lemonsqueezy.com/settings/api
LEMONSQUEEZY_API_KEY=eyJ...
LEMONSQUEEZY_STORE_ID=12345
LEMONSQUEEZY_WEBHOOK_SECRET=whsec_xxxxxxxxxxxx

# -----------------------------------------------------------------------------
# Optional: Monitoring & Logging
# -----------------------------------------------------------------------------
# LOG_LEVEL=info
# SENTRY_DSN=https://xxxxx@sentry.io/xxxxx

# =============================================================================
# Checklist before deploying:
# =============================================================================
# [ ] All secrets are strong and unique
# [ ] Database is accessible and migrations applied
# [ ] Redis is accessible
# [ ] OAuth apps configured with correct callback URLs
# [ ] Email service verified (Resend domain verified)
# [ ] HTTPS configured on your domain
# [ ] Webhook endpoints registered with LemonSqueezy
# =============================================================================
