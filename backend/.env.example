# Database
DATABASE_URL=postgres://gengo:devpass@localhost:5433/gengowatcher
DB_HOST=localhost
DB_PORT=5433
DB_USER=gengo
DB_PASSWORD=devpass
DB_NAME=gengowatcher
DB_SSLMODE=disable

# Server
HOST=
PORT=37181
ENV=development

# JWT (BetterAuth will handle this, but keep for server-side validation)
JWT_SECRET=your-secret-key-here

# Redis
REDIS_URL=redis://localhost:6380/0

# Watcher browser worker
# Optional: leave WATCHER_BROWSER_BINARY blank to auto-detect chromium/google-chrome/brave.
# Set firefox-rdp + a ws:// debug URL to attach to the existing Firefox
# DevTools/RDP session instead of launching Chromium.
WATCHER_BROWSER_BACKEND=
WATCHER_BROWSER_DEBUG_URL=
WATCHER_BROWSER_BINARY=
WATCHER_BROWSER_PROFILE_ROOT=../data/watcher-profiles
WATCHER_BROWSER_ARTIFACT_ROOT=../data/watcher-artifacts
# Blank auto-selects headless when no DISPLAY/WAYLAND display is available.
WATCHER_BROWSER_HEADLESS=
WATCHER_BROWSER_DISABLED=false
WATCHER_BROWSER_START_TIMEOUT=15s
WATCHER_BROWSER_ACTION_TIMEOUT=12s
WATCHER_BROWSER_HEARTBEAT_INTERVAL=30s
WATCHER_BROWSER_ACCEPT_SELECTOR=text=Accept

# Email (Resend)
RESEND_API_KEY=

# Cookies
COOKIE_SECURE=false    # Set to 'true' in production (HTTPS required)
COOKIE_DOMAIN=         # Cookie domain (empty for localhost, ".example.com" for prod)
COOKIE_SAMESITE=Lax    # SameSite policy: "Lax", "Strict", or "None"

# LemonSqueezy
LEMONSQUEZY_API_KEY=
LEMONSQUEZY_STORE_ID=
LEMONSQUEZY_WEBHOOK_SECRET=
