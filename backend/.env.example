# Database
DATABASE_URL=postgres://gengo:devpass@localhost:5432/gengowatcher
DB_HOST=localhost
DB_PORT=5432
DB_USER=gengo
DB_PASSWORD=devpass
DB_NAME=gengowatcher
DB_SSLMODE=disable

# Server
PORT=8000
ENV=development

# JWT (BetterAuth will handle this, but keep for server-side validation)
JWT_SECRET=your-secret-key-here

# Redis
REDIS_URL=redis://localhost:6379/0

# Email (Resend)
RESEND_API_KEY=

# Cookies
COOKIE_SECURE=false    # Set to 'true' in production (HTTPS required)
COOKIE_DOMAIN=         # Cookie domain (empty for localhost, ".example.com" for prod)
COOKIE_SAMESITE=Lax    # SameSite policy: "Lax", "Strict", or "None"

# LemonSqueezy
LEMONSQUEZY_API_KEY=
LEMONSQUEZY_STORE_ID=
LEMONSQUEZY_WEBHOOK_SECRET=
