# GengoWatcher SaaS Environment Variables

# ============================================================================
# SERVER
# ============================================================================
HOST=
PORT=37181
ENV=development

# ============================================================================
# DATABASE (PostgreSQL)
# ============================================================================
DB_HOST=localhost
DB_PORT=5433
DB_USER=gengo
DB_PASSWORD=your-db-password
DB_NAME=gengowatcher
DB_SSLMODE=disable

# ============================================================================
# SECURITY
# ============================================================================
# Generate with: openssl rand -hex 32
JWT_SECRET=
LEMONSQUEEZY_WEBHOOK_SECRET=

# ============================================================================
# CORS
# ============================================================================
ALLOWED_ORIGINS=http://localhost:37180

# ============================================================================
# REDIS
# ============================================================================
REDIS_URL=redis://localhost:6380/0

# ============================================================================
# WATCHER BROWSER WORKER
# ============================================================================
# Optional: leave blank to auto-detect chromium/google-chrome/brave.
# Set firefox-rdp + a ws:// debug URL to attach to the existing Firefox
# DevTools/RDP session instead of launching Chromium.
WATCHER_BROWSER_BACKEND=
WATCHER_BROWSER_DEBUG_URL=
WATCHER_BROWSER_BINARY=
WATCHER_BROWSER_PROFILE_ROOT=data/watcher-profiles
WATCHER_BROWSER_ARTIFACT_ROOT=data/watcher-artifacts
# Blank auto-selects headless when no DISPLAY/WAYLAND display is available.
WATCHER_BROWSER_HEADLESS=
WATCHER_BROWSER_DISABLED=false
WATCHER_BROWSER_START_TIMEOUT=15s
WATCHER_BROWSER_ACTION_TIMEOUT=12s
WATCHER_BROWSER_HEARTBEAT_INTERVAL=30s
WATCHER_BROWSER_ACCEPT_SELECTOR=text=Accept

# ============================================================================
# LEMONSQUEEZY (Billing)
# ============================================================================
LEMONSQUEZEZY_STORE_ID=
LEMONSQUEEZY_API_KEY=
LEMONSQUEEZY_WEBHOOK_SECRET=

# ============================================================================
# EMAIL (Resend)
# ============================================================================
RESEND_API_KEY=
FROM_EMAIL=noreply@gengowatcher.com
FROM_NAME=GengoWatcher

# ============================================================================
# OAUTH - Google (optional)
# ============================================================================
OAUTH_GOOGLE_CLIENT_ID=
OAUTH_GOOGLE_CLIENT_SECRET=

# ============================================================================
# OAUTH - GitHub (optional)
# ============================================================================
OAUTH_GITHUB_CLIENT_ID=
OAUTH_GITHUB_CLIENT_SECRET=
